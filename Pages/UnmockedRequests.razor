@page "/unmocked"
@using Savio.MockServer.Data.Repositories
@using Savio.MockServer.Data.Entities
@using Savio.MockServer.Services
@inject IUnmockedRequestRepository UnmockedRepo
@inject MockService MockService
@inject NavigationManager Navigation

<PageTitle>Requisições Não Mockadas</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-3">
        <div class="col">
            <h2 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Requisições Não Mockadas</h2>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadUnmockedRequests">
                <i class="bi bi-arrow-clockwise"></i> Atualizar
            </button>
        </div>
    </div>

    @if (unmockedRequests == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else if (!unmockedRequests.Any())
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle"></i> Todas as requisições têm mocks correspondentes!
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Método</th>
                        <th>Rota</th>
                        <th>Primeira Vez</th>
                        <th>Última Vez</th>
                        <th>Hits</th>
                        <th>Último IP</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in unmockedRequests)
                    {
                        <tr>
                            <td><span class="badge bg-@UiHelpers.GetMethodColor(item.Method)">@item.Method</span></td>
                            <td><code>@item.Route</code></td>
                            <td><small>@TimezoneService.FormatLocalTime(item.FirstSeenAt, "dd/MM/yyyy HH:mm:ss")</small></td>
                            <td><small>@TimezoneService.FormatLocalTime(item.LastSeenAt, "dd/MM/yyyy HH:mm:ss")</small></td>
                            <td><span class="badge bg-warning text-dark">@item.HitCount</span></td>
                            <td><small>@item.LastClientIp</small></td>
                            <td>
                                <button class="btn btn-sm btn-success" @onclick="() => CreateMockFromRequest(item)">
                                    <i class="bi bi-plus-circle"></i> Criar Mock
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRequest(item.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginação -->
        @if (totalPages > 1)
        {
            <nav aria-label="Paginação">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Anterior</button>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNumber = i;
                        <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                            <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Próxima</button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@* code-behind: UnmockedRequests.razor.cs *@
