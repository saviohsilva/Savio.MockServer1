@page "/historico"
@using Savio.MockServer.Data
@using Savio.MockServer.Data.Repositories
@using Savio.MockServer.Data.Entities
@using Savio.MockServer.Models
@using Savio.MockServer.Components
@inject IRequestHistoryRepository HistoryRepo
@inject MockDbContext _context
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Histórico de Requisições</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4"><i class="bi bi-clock-history"></i> Histórico de Requisições</h1>
            <p class="lead">Total de @totalCount requisições registradas</p>
        </div>
        <div class="col-auto">
            <select class="form-select form-select-sm me-2" style="width: auto; display: inline-block;" @bind="pageSize" @bind:after="OnPageSizeChanged">
                <option value="50">50 por página</option>
                <option value="100">100 por página</option>
                <option value="200">200 por página</option>
            </select>
            <button class="btn btn-outline-secondary btn-sm me-2" @onclick="LoadHistory">
                <i class="bi bi-arrow-clockwise"></i> Atualizar
            </button>
            <button class="btn btn-outline-danger btn-sm" @onclick="ClearHistory" disabled="@(totalCount == 0)">
                <i class="bi bi-trash"></i> Limpar histórico
            </button>
        </div>
    </div>

    @if (MockId.HasValue)
    {
        <div class="card border-info mb-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1">
                        <i class="bi bi-funnel-fill text-info"></i> Histórico filtrado por mock
                    </h5>
                    <span class="text-muted">
                        @if (!string.IsNullOrWhiteSpace(mockRoute))
                        {
                            <span class="badge bg-@UiHelpers.GetMethodColor(mockMethod ?? "")">@mockMethod</span>
                            <code class="ms-1">@mockRoute</code>
                            @if (!string.IsNullOrWhiteSpace(mockDescription) && mockDescription != $"{mockMethod} {mockRoute}")
                            {
                                <span class="ms-2">— @mockDescription</span>
                            }
                        }
                        else
                        {
                            <span>@mockDescription</span>
                        }
                    </span>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-info" @onclick="ClearMockFilter">
                        <i class="bi bi-x-circle"></i> Ver todo o histórico
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-2">
                    <label class="form-label small text-muted">Método</label>
                    <select class="form-select form-select-sm" @bind="filterState.Method" @bind:after="OnFilterChanged">
                        <option value="">Todos</option>
                        <option value="GET">GET</option>
                        <option value="POST">POST</option>
                        <option value="PUT">PUT</option>
                        <option value="PATCH">PATCH</option>
                        <option value="DELETE">DELETE</option>
                    </select>
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label small text-muted">Rota contém</label>
                    <input class="form-control form-control-sm" placeholder="Ex: /api/pedido" @bind="filterState.RouteContains" @bind:after="OnFilterChanged" />
                </div>

                <div class="col-12 col-md-2">
                    <label class="form-label small text-muted">Status</label>
                    <input class="form-control form-control-sm" type="number" min="100" max="599" placeholder="Ex: 200" @bind="filterState.StatusCode" @bind:after="OnFilterChanged" />
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label small text-muted">Texto contém</label>
                    <input class="form-control form-control-sm" placeholder="Request/Response/IP" @bind="filterState.TextContains" @bind:after="OnFilterChanged" />
                </div>

                <div class="col-12 col-md-2">
                    <DateTimeLocalFilter FromUtc="@filterState.FromUtc" ToUtc="@filterState.ToUtc" OnRangeChanged="@OnDateRangeChanged" />
                </div>
            </div>

            <div class="mt-2 d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearFilters">
                    <i class="bi bi-x-circle"></i> Limpar filtros
                </button>
            </div>
        </div>
    </div>

    @if (history == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else if (!history.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Nenhuma requisição registrada para os filtros atuais.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Data/Hora</th>
                        <th>Método</th>
                        <th>Rota</th>
                        <th>Status</th>
                        <th>Delay</th>
                        <th>IP</th>
                        <th>Mock</th>
                        <th style="width: 140px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in history)
                    {
                        <tr>
                            <td>@TimezoneService.FormatLocalTime(item.RequestedAt, "dd/MM/yyyy HH:mm:ss")</td>
                            <td><span class="badge bg-@UiHelpers.GetMethodColor(item.Method)">@item.Method</span></td>
                            <td><code>@item.Route</code></td>
                            <td><span class="badge bg-@UiHelpers.GetStatusColor(item.ResponseStatusCode)">@item.ResponseStatusCode</span></td>
                            <td>@item.DelayMs ms</td>
                            <td>@item.ClientIp</td>
                            <td>
                                @if (item.MockEndpoint != null)
                                {
                                    <small class="text-muted">@item.MockEndpoint.Description</small>
                                }
                            </td>
                            <td class="d-flex gap-1">
                                <a href="/historico/@item.Id" class="btn btn-sm btn-outline-primary" title="Ver detalhes">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger" title="Excluir" @onclick="() => DeleteItem(item.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav aria-label="Paginação">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Anterior</button>
                    </li>

                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        var pageNumber = i;
                        <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                            <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Próxima</button>
                    </li>
                </ul>
                <p class="text-center text-muted small">
                    Página @currentPage de @totalPages (exibindo @history.Count de @totalCount registros)
                </p>
            </nav>
        }
    }
</div>

@* code-behind: Historico.razor.cs *@
