@page "/historico/{Id:int}"
@using Savio.MockServer.Data.Repositories
@using Savio.MockServer.Data.Entities
@using Savio.MockServer.Models
@using Savio.MockServer.Services
@using System.Text.Json
@using System.Text
@inject IRequestHistoryRepository HistoryRepo
@inject IMockBinaryStorage BinaryStorage
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Detalhes da Requisição</PageTitle>

<div class="container-fluid py-4">
    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else if (history == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Registro não encontrado.
        </div>
        <button class="btn btn-secondary" @onclick="VoltarParaLista">
            <i class="bi bi-arrow-left"></i> Voltar
        </button>
    }
    else
    {
        <div class="row mb-4">
            <div class="col">
                <h1 class="display-4">📋 Detalhes da Requisição</h1>
                <p class="lead">
                    <span class="badge bg-@UiHelpers.GetMethodColor(history.Method)">@history.Method</span>
                    <code>@history.Route</code>
                </p>
            </div>
            <div class="col-auto d-flex gap-2">
                <button class="btn btn-outline-danger" @onclick="Excluir">
                    <i class="bi bi-trash"></i> Excluir
                </button>
                <button class="btn btn-secondary" @onclick="VoltarParaLista">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
            </div>
        </div>

        <div class="row">
            <!-- Informações Gerais -->
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">ℹ️ Informações Gerais</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tbody>
                                <tr>
                                    <th style="width: 180px;">Data/Hora:</th>
                                    <td>@TimezoneService.FormatLocalTime(history.RequestedAt, "dd/MM/yyyy HH:mm:ss")</td>
                                </tr>
                                <tr>
                                    <th>Status Code:</th>
                                    <td><span class="badge bg-@UiHelpers.GetStatusColor(history.ResponseStatusCode)">@history.ResponseStatusCode</span></td>
                                </tr>
                                <tr>
                                    <th>Delay:</th>
                                    <td>@history.DelayMs ms</td>
                                </tr>
                                <tr>
                                    <th>IP do Cliente:</th>
                                    <td><code>@history.ClientIp</code></td>
                                </tr>
                                @if (history.MockEndpoint != null)
                                {
                                    <tr>
                                        <th>Mock:</th>
                                        <td>@history.MockEndpoint.Description</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Request Headers -->
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">📤 Request Headers</h5>
                    </div>
                    <div class="card-body">
                        @if (requestHeaders != null && requestHeaders.Any())
                        {
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var header in requestHeaders.OrderBy(h => h.Key))
                                    {
                                        <tr>
                                            <td><strong>@header.Key</strong></td>
                                            <td><code class="small">@header.Value</code></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Nenhum header</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Request Body -->
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">📥 Request Body</h5>
                        @if (!string.IsNullOrEmpty(history.RequestBody))
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => CopyToClipboard(history.RequestBody)">
                                <i class="bi bi-clipboard"></i> Copiar
                            </button>
                        }
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(history.RequestFormJson))
                        {
                            <h6 class="text-muted">Form/MultiPart (normalizado)</h6>
                            <pre class="bg-light p-3 rounded" style="max-height: 400px; overflow: auto;"><code>@UiHelpers.FormatJson(history.RequestFormJson)</code></pre>
                        }
                        else if (!string.IsNullOrEmpty(history.RequestBody))
                        {
                            <pre class="bg-light p-3 rounded" style="max-height: 400px; overflow: auto;"><code>@UiHelpers.FormatJson(history.RequestBody)</code></pre>
                        }
                        else if (!string.IsNullOrEmpty(history.RequestBodyBase64))
                        {
                            <p class="text-muted">Request binário capturado (Base64) - ContentType: <code>@history.RequestBodyContentType</code></p>
                            <pre class="bg-light p-3 rounded" style="max-height: 200px; overflow: auto;"><code>@history.RequestBodyBase64</code></pre>
                        }
                        else
                        {
                            <p class="text-muted">Vazio</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Response Headers -->
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">📥 Response Headers</h5>
                    </div>
                    <div class="card-body">
                        @if (responseHeaders != null && responseHeaders.Any())
                        {
                            <table class="table table-sm table-hover">
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var header in responseHeaders.OrderBy(h => h.Key))
                                    {
                                        <tr>
                                            <td><strong>@header.Key</strong></td>
                                            <td><code class="small">@header.Value</code></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Nenhum header</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Response Body -->
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">📤 Response Body</h5>
                        <div class="d-flex gap-2">
                            @if (!string.IsNullOrEmpty(history.ResponseBody) && !history.ResponseBody.StartsWith("[Response"))
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => CopyToClipboard(history.ResponseBody)">
                                    <i class="bi bi-clipboard"></i> Copiar
                                </button>
                            }
                            @if (history.ResponseBinaryBlobId.HasValue)
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="DownloadResponseBlob">
                                    <i class="bi bi-download"></i> Baixar Response Grande
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(history.ResponseBodyBase64))
                            {
                                <a class="btn btn-sm btn-outline-success" href="@GetResponseDownloadUrl()" download="@GetResponseFileName()">
                                    <i class="bi bi-download"></i> Baixar
                                </a>
                            }
                        </div>
                    </div>
                    <div class="card-body">
                        @if (history.ResponseBinaryBlobId.HasValue)
                        {
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> Response body muito grande (armazenado como blob #@history.ResponseBinaryBlobId).
                                <br />
                                <strong>ContentType:</strong> <code>@(history.ResponseBodyContentType ?? "application/octet-stream")</code>
                                @if (responseBlobContent != null)
                                {
                                    <hr />
                                    <div>
                                        <strong>Tamanho:</strong> @FormatFileSize(responseBlobContent.Length)
                                    </div>
                                    @if (IsTextContent(history.ResponseBodyContentType))
                                    {
                                        <h6 class="mt-3">Preview (primeiros 10.000 caracteres):</h6>
                                        <pre class="bg-light p-3 rounded" style="max-height: 500px; overflow: auto;"><code>@GetTextPreview(responseBlobContent)</code></pre>
                                    }
                                }
                                else if (loadingBlobContent)
                                {
                                    <div class="spinner-border spinner-border-sm mt-2" role="status">
                                        <span class="visually-hidden">Carregando...</span>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary mt-2" @onclick="LoadResponseBlobContent">
                                        <i class="bi bi-eye"></i> Carregar Preview
                                    </button>
                                }
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(history.ResponseBodyBase64))
                        {
                            <p class="text-muted">Response binário - ContentType: <code>@history.ResponseBodyContentType</code></p>
                            <pre class="bg-light p-3 rounded" style="max-height: 200px; overflow: auto;"><code>@history.ResponseBodyBase64</code></pre>
                        }
                        else if (!string.IsNullOrEmpty(history.ResponseBody))
                        {
                            <pre class="bg-light p-3 rounded" style="max-height: 500px; overflow: auto;"><code>@UiHelpers.FormatJson(history.ResponseBody)</code></pre>
                        }
                        else
                        {
                            <p class="text-muted">Vazio</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

